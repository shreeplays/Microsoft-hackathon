{
  "name": "ai-code-visualizer",
  "displayName": "AI Code Visualizer",
  "description": "Visualize Python code as flowcharts, architecture, sequence & class diagrams using AI.",
  "version": "2.0.0",
  "publisher": "your-publisher-id",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
  "commands": [
    {
      "command": "aiCodeVisualizer.visualizeFile",
      "title": "Visualize Current File"
    },
    {
      "command": "aiCodeVisualizer.analyzeWorkspace",
      "title": "Visualize Folder"
    }
  ],

    "menus": {
  "editor/title": [
    {
      "command": "aiCodeVisualizer.visualizeFile",
      "when": "editorTextFocus",
      "group": "navigation"
    },
    {
      "command": "aiCodeVisualizer.analyzeWorkspace",
      "when": "editorTextFocus",
      "group": "navigation"
    }
  ]
},
    "explorer/context": [
      {
        "command": "aiCodeVisualizer.analyzeWorkspace",
        "when": "explorerResourceIsFolder",
        "group": "navigation"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}